#include <iostream>
#include <vector>
#include <algorithm>
#include <queue>
#include <utility>

using namespace std;
using ll = long long;

int dx[] = {-1, 0, 0, 1};
int dy[] = {0, -1, 1, 0};

int n, m;
int map[1001][1001];
bool wall[1001][1001];

void print() {
    // for test
    cout << endl;
    for(int i=0; i<n; i++) {
        for(int j=0; j<m; j++) {
            cout << map[i][j] << " ";
        } cout << endl;
    }
}

int main() {
    ios::sync_with_stdio(false);
    cin.tie(NULL);
    cout.tie(NULL);

    // 15:48
    
    vector<pair<int,int>> fire;
    queue<pair<int,int>> q;
    queue<pair<int,int>> fireq;

    char c;
    cin >> n >> m;
    for(int i=0; i<n; i++) {
        for(int j=0; j<m; j++) {
            cin >> c;
            if(c== '#') wall[i][j] = true;
            else if(c== 'J') {
                map[i][j] = 1;
                q.push({i, j});

                if(i == 0 || i == n-1 || j == 0 || j == m-1){
                    cout << 1; return 0;
                }
            }
            else if(c== 'F') {
                map[i][j] = -1;
                fireq.push({i, j});
            }
        }
    }


    int x, y, dist;
    for(int time=1; ; time++) {
        if(q.empty()) {
            cout << "IMPOSSIBLE"; 
            // print(); // for test
            return 0;
        }

        while(!q.empty()) {
            // cout << x <<", " << y << endl;
            // 지훈
            x = q.front().first;
            y = q.front().second;
            dist = map[x][y];
            if(dist < 0) {
                q.pop(); continue;
            }
            if(dist != time) break; // 불이 왔거나, 다음 턴
            q.pop();
            

            if(x == 0 || x == n-1 || y == 0 || y == m-1) {
                cout << dist; 
                // print(); // for test
                return 0;
            }

            for(int k=0; k<4; k++) {
                int nx = x + dx[k], ny = y + dy[k];
                if(0<=nx&&nx<n&&0<=ny&&ny<m && !wall[nx][ny] && map[nx][ny] == 0) {
                    map[nx][ny] = dist + 1;
                    q.push({nx, ny});
                }
            }
        }

        // fire
        while(!fireq.empty()) {
            x = fireq.front().first;
            y = fireq.front().second;
            dist = map[x][y];
            if(-dist != time) break;

            fireq.pop();
            
            for(int k=0; k<4; k++) {
                int nx = x + dx[k], ny = y + dy[k];
                if(0<=nx&&nx<n&&0<=ny&&ny<m && !wall[nx][ny] && map[nx][ny] >= 0) {
                    map[nx][ny] = dist - 1;
                    fireq.push({nx, ny});
                }
            }
        }
        // print();
    }

    
}   